# Copy to .env (cp .env.example .env) and edit. .env is gitignored.

# --- telegram ------------------------------------------------------------

# Bot token from @BotFather. Leave empty for step 1 (Pi guides you through
# creating one); fill it in for step 2 (starting the bridge).
TELEGRAM_BOT_TOKEN=

# Recover mode (optional): seed access from env so a fresh container with no
# state file boots already owned and ready, no claim link needed. Numeric
# Telegram ids; get yours from @userinfobot, or claim once and copy it from
# bot-state.json. TRUSTED/GUEST/BLOCKED are comma-separated lists.
OWNER_ID=
TRUSTED_IDS=
GUEST_IDS=
BLOCKED_IDS=

# --- model (mirrors hec-ovi/llama-vulkan-strix) ----------------------------

# Host folder holding your GGUF files (mounted read-only at /models).
MODELS_DIR=/home/hec/models/gguf

# The GGUF to serve, RELATIVE to MODELS_DIR. The reference test model is
# deliberately small-brained: Gemma 4 26B MoE (about 4B active per token).
LLM_MODEL=gemma-4-26B-A4B-it-heretic/gemma-4-26B-A4B-it-heretic.Q4_K_M.gguf

# Model name reported by the OpenAI API; pi refers to it as local/<alias>.
LLM_ALIAS=llm

# Host port for the llama.cpp API (containers talk over the compose network,
# this is only for curl-from-host debugging).
LLM_PORT=8080

# Layers offloaded to GPU (99 = all), context window, request slots.
LLM_NGL=99
LLM_CTX=32768
LLM_PARALLEL=1

# --- GPU access (Strix Halo) ----------------------------------------------

# Group IDs so the container can reach /dev/dri. Find yours:
#   getent group render | cut -d: -f3   -> RENDER_GID
#   getent group video  | cut -d: -f3   -> VIDEO_GID
RENDER_GID=990
VIDEO_GID=44
