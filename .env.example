# telegram-bot-skill config template.
# Copy to .env (cp .env.example .env), fill it in, never commit it.
# `npm start` reads ./.env by itself. `npm run setup` can validate the token,
# fill in the bot username, and set the file to mode 600 for you.

# The bot token from @BotFather. This is a SECRET: anyone who has it controls
# your bot. Prefer writing it here over pasting it into a chat with an agent.
TELEGRAM_BOT_TOKEN=

# The bot's @username. Informational; `npm run setup` fills it automatically.
BOT_USERNAME=

# Recover mode (optional): numeric Telegram ids seeded at every boot, so a
# fresh machine or wiped state file comes up already owned, no claim link.
# Get your id from @userinfobot. Lists are comma-separated.
OWNER_ID=
TRUSTED_IDS=
GUEST_IDS=
BLOCKED_IDS=

# Which agent answers: claude-code (default) or pi. For pi, set the model
# ref too, e.g. PI_MODEL=local/llm
AGENT_ADAPTER=
PI_MODEL=

# Paths (optional): the folder the agent works in, and where state lives.
AGENT_CWD=
STATE_FILE=
